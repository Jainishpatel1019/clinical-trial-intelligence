ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Gemini (used when set; takes priority over Anthropic for RAG answers)
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative name Google documents for the same key:
# GOOGLE_API_KEY=...
# Stable model ids change over time; see https://ai.google.dev/gemini-api/docs/models
# Leave unset to auto-try gemini-2.5-flash, gemini-flash-latest, etc.
# GEMINI_MODEL=gemini-2.5-flash
DEMO_MODE=true
DB_PATH=data/trials.duckdb
FAISS_INDEX_PATH=data/faiss_index
